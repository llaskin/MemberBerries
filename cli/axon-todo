#!/usr/bin/env bash
# axon-todo — Per-project TODO list management
# Usage: axon todo <add|done|defer|drop|list|reprioritise> [args]
# Reads/writes: ~/.axon/workspaces/{project}/todos.md + todos-log.md

set -euo pipefail

AXON_HOME="${AXON_HOME:-$HOME/.axon}"
PROJECT="${PROJECT:-$(basename "$PWD")}"
WORKSPACE="$AXON_HOME/workspaces/$PROJECT"
TODOS_FILE="$WORKSPACE/todos.md"
LOG_FILE="$WORKSPACE/todos-log.md"
STREAM_FILE="$WORKSPACE/stream.md"
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
TODAY=$(date +%Y-%m-%d)

# Check initialized
if [[ ! -d "$WORKSPACE" ]]; then
    echo "Project '$PROJECT' is not initialized. Run: axon init --project $PROJECT"
    exit 1
fi

# Initialize todos.md if it doesn't exist
init_todos() {
    if [[ ! -f "$TODOS_FILE" ]]; then
        cat > "$TODOS_FILE" << EOF
---
type: todos
project: $PROJECT
updated_at: $NOW
---

## Active

## Completed

## Deferred

## Dropped
EOF
        touch "$LOG_FILE"
    fi
}

# Get the next sequential ID by scanning all sections
next_id() {
    if [[ ! -f "$TODOS_FILE" ]]; then
        echo 1
        return
    fi
    local max_id
    max_id=$(grep -oE '#[0-9]+' "$TODOS_FILE" 2>/dev/null | sed 's/#//' | sort -rn | head -1)
    echo $(( ${max_id:-0} + 1 ))
}

# Atomic write: temp file + mv
atomic_write() {
    local target="$1"
    local content="$2"
    local tmpfile
    tmpfile=$(mktemp "$WORKSPACE/.todos.tmp.XXXXXX")
    echo "$content" > "$tmpfile"
    mv "$tmpfile" "$target"
}

# Update the updated_at timestamp in frontmatter
update_timestamp() {
    local content="$1"
    echo "$content" | sed "s/^updated_at: .*/updated_at: $NOW/"
}

# Log mutation to todos-log.md and stream.md
log_mutation() {
    local action="$1"
    local id="$2"
    local desc="$3"
    local extra="${4:-}"

    local log_line="[$NOW] $action #$id \"$desc\""
    [[ -n "$extra" ]] && log_line="$log_line $extra"

    echo "$log_line" >> "$LOG_FILE"
    echo "- [$NOW] @axon: todo $action #$id \"$desc\" ${extra}" >> "$STREAM_FILE"
}

# ---- SUBCOMMANDS ----

cmd_add() {
    local priority="medium"
    local desc=""
    local notes=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --priority|-p)
                [[ $# -lt 2 ]] && { echo "Error: --priority requires a value (high|medium|low)"; exit 1; }
                priority="$2"
                if [[ "$priority" != "high" && "$priority" != "medium" && "$priority" != "low" ]]; then
                    echo "Error: priority must be high, medium, or low"
                    exit 1
                fi
                shift 2 ;;
            --notes|-n)
                [[ $# -lt 2 ]] && { echo "Error: --notes requires a value"; exit 1; }
                notes="$2"; shift 2 ;;
            *)
                if [[ -z "$desc" ]]; then
                    desc="$1"
                else
                    desc="$desc $1"
                fi
                shift ;;
        esac
    done

    if [[ -z "$desc" ]]; then
        echo "Usage: axon todo add \"task description\" [--priority high|medium|low] [--notes \"details\"]"
        exit 1
    fi

    init_todos

    local id
    id=$(next_id)
    local new_block="- [ ] #$id $desc [created: $TODAY] [priority: $priority]"
    # Append notes as indented continuation lines
    if [[ -n "$notes" ]]; then
        while IFS= read -r noteline; do
            new_block="$new_block
    $noteline"
        done <<< "$notes"
    fi

    # Insert after ## Active heading
    local content
    content=$(cat "$TODOS_FILE")
    content=$(echo "$content" | awk -v block="$new_block" '
        /^## Active/ { print; print block; next }
        { print }
    ')
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "ADD" "$id" "$desc" "priority=$priority"

    echo "Added #$id: $desc [priority: $priority]"
    [[ -n "$notes" ]] && echo "  Notes: $notes"
}

cmd_done() {
    local id="$1"
    if [[ -z "$id" ]]; then
        echo "Usage: axon todo done <id>"
        exit 1
    fi
    # Strip # prefix if provided
    id="${id#\#}"

    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos.md found. Add a todo first."
        exit 1
    fi

    # Find the item
    local line
    line=$(grep -n "#$id " "$TODOS_FILE" | head -1)
    if [[ -z "$line" ]]; then
        echo "Error: todo #$id not found"
        exit 1
    fi

    local desc
    desc=$(echo "$line" | sed "s/.*#$id //" | sed 's/ \[.*//')

    local content
    content=$(cat "$TODOS_FILE")

    # Remove from current location
    content=$(echo "$content" | grep -v "#$id ")

    # Build completed line
    local completed_line="- [x] #$id $desc [created: $TODAY] [completed: $TODAY]"

    # Insert after ## Completed heading
    content=$(echo "$content" | awk -v line="$completed_line" '
        /^## Completed/ { print; print line; next }
        { print }
    ')
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "COMPLETE" "$id" "$desc"

    echo "Completed #$id: $desc"
}

cmd_defer() {
    local id=""
    local reason=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --reason|-r)
                [[ $# -lt 2 ]] && { echo "Error: --reason requires a value"; exit 1; }
                reason="$2"; shift 2 ;;
            *)
                if [[ -z "$id" ]]; then
                    id="${1#\#}"
                fi
                shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: axon todo defer <id> [--reason \"why\"]"
        exit 1
    fi

    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos.md found. Add a todo first."
        exit 1
    fi

    local line
    line=$(grep -n "#$id " "$TODOS_FILE" | head -1)
    if [[ -z "$line" ]]; then
        echo "Error: todo #$id not found"
        exit 1
    fi

    local desc
    desc=$(echo "$line" | sed "s/.*#$id //" | sed 's/ \[.*//')

    local content
    content=$(cat "$TODOS_FILE")
    content=$(echo "$content" | grep -v "#$id ")

    local deferred_line="- [>] #$id $desc [created: $TODAY] [deferred: $TODAY]"
    [[ -n "$reason" ]] && deferred_line="$deferred_line [reason: $reason]"

    content=$(echo "$content" | awk -v line="$deferred_line" '
        /^## Deferred/ { print; print line; next }
        { print }
    ')
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "DEFER" "$id" "$desc" "reason=\"${reason:-unspecified}\""

    echo "Deferred #$id: $desc"
    [[ -n "$reason" ]] && echo "  Reason: $reason"
}

cmd_drop() {
    local id=""
    local reason=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --reason|-r)
                [[ $# -lt 2 ]] && { echo "Error: --reason requires a value"; exit 1; }
                reason="$2"; shift 2 ;;
            *)
                if [[ -z "$id" ]]; then
                    id="${1#\#}"
                fi
                shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: axon todo drop <id> [--reason \"why\"]"
        exit 1
    fi

    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos.md found. Add a todo first."
        exit 1
    fi

    local line
    line=$(grep -n "#$id " "$TODOS_FILE" | head -1)
    if [[ -z "$line" ]]; then
        echo "Error: todo #$id not found"
        exit 1
    fi

    local desc
    desc=$(echo "$line" | sed "s/.*#$id //" | sed 's/ \[.*//')

    local content
    content=$(cat "$TODOS_FILE")
    content=$(echo "$content" | grep -v "#$id ")

    local dropped_line="- [-] #$id $desc [created: $TODAY] [dropped: $TODAY]"
    [[ -n "$reason" ]] && dropped_line="$dropped_line [reason: $reason]"

    content=$(echo "$content" | awk -v line="$dropped_line" '
        /^## Dropped/ { print; print line; next }
        { print }
    ')
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "DROP" "$id" "$desc" "reason=\"${reason:-unspecified}\""

    echo "Dropped #$id: $desc"
    [[ -n "$reason" ]] && echo "  Reason: $reason"
}

cmd_list() {
    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos for $PROJECT. Add one: axon todo add \"task\" --priority high"
        exit 0
    fi

    local filter="${1:-active}"
    echo "=== $PROJECT — TODOs ==="
    echo ""

    case "$filter" in
        active|now)
            echo "Active:"
            awk '/^## Active$/{f=1;next} f && /^## /{exit} f && /^\- \[/' "$TODOS_FILE" | while IFS= read -r line; do
                id=$(echo "$line" | grep -oE '#[0-9]+' | head -1)
                desc=$(echo "$line" | sed "s/.*$id //" | sed 's/ \[.*//')
                priority=$(echo "$line" | grep -oE '\[priority: [a-z]+\]' | sed 's/\[priority: //' | sed 's/\]//')

                pri_marker="·"
                [[ "$priority" == "high" ]] && pri_marker="●"
                [[ "$priority" == "medium" ]] && pri_marker="◐"
                [[ "$priority" == "low" ]] && pri_marker="○"

                printf "  %s %s %s\n" "$pri_marker" "$id" "$desc"
            done || true
            ;;
        backlog)
            echo "Deferred:"
            awk '/^## Deferred$/{f=1;next} f && /^## /{exit} f && /^\- \[/' "$TODOS_FILE" || echo "  (none)"
            ;;
        done)
            echo "Completed:"
            awk '/^## Completed$/{f=1;next} f && /^## /{exit} f && /^\- \[/' "$TODOS_FILE" || echo "  (none)"
            echo ""
            echo "Dropped:"
            awk '/^## Dropped$/{f=1;next} f && /^## /{exit} f && /^\- \[/' "$TODOS_FILE" || echo "  (none)"
            ;;
        all)
            cmd_list "active"
            echo ""
            cmd_list "backlog"
            echo ""
            cmd_list "done"
            ;;
        *)
            echo "Unknown filter: $filter (use: active, backlog, done, all)"
            exit 1
            ;;
    esac
}

cmd_reprioritise() {
    local id="${1:-}"
    local new_priority="${2:-}"

    if [[ -z "$id" || -z "$new_priority" ]]; then
        echo "Usage: axon todo reprioritise <id> <high|medium|low>"
        exit 1
    fi

    id="${id#\#}"

    if [[ "$new_priority" != "high" && "$new_priority" != "medium" && "$new_priority" != "low" ]]; then
        echo "Error: priority must be high, medium, or low"
        exit 1
    fi

    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos.md found."
        exit 1
    fi

    local line
    line=$(grep "#$id " "$TODOS_FILE" | head -1)
    if [[ -z "$line" ]]; then
        echo "Error: todo #$id not found"
        exit 1
    fi

    local desc
    desc=$(echo "$line" | sed "s/.*#$id //" | sed 's/ \[.*//')

    # Replace priority in-place
    local content
    content=$(cat "$TODOS_FILE")
    content=$(echo "$content" | sed "s/\(#$id .*\)\[priority: [a-z]*\]/\1[priority: $new_priority]/")
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "REPRIORITISE" "$id" "$desc" "priority=$new_priority"

    echo "Reprioritised #$id to $new_priority: $desc"
}

cmd_note() {
    local id="${1:-}"
    shift || true
    local note_text="$*"

    if [[ -z "$id" || -z "$note_text" ]]; then
        echo "Usage: axon todo note <id> \"note text\""
        exit 1
    fi
    id="${id#\#}"

    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "No todos.md found."
        exit 1
    fi

    # Find the line number of the item
    local line_num
    line_num=$(grep -n "#$id " "$TODOS_FILE" | head -1 | cut -d: -f1)
    if [[ -z "$line_num" ]]; then
        echo "Error: todo #$id not found"
        exit 1
    fi

    local desc
    desc=$(sed -n "${line_num}p" "$TODOS_FILE" | sed "s/.*#$id //" | sed 's/ \[.*//')

    # Insert note line after the item (and any existing notes)
    local content
    content=$(cat "$TODOS_FILE")
    local insert_after=$line_num
    local total_lines
    total_lines=$(echo "$content" | wc -l)
    # Skip past existing indented note lines
    while [[ $insert_after -lt $total_lines ]]; do
        local next_line
        next_line=$(echo "$content" | sed -n "$((insert_after + 1))p")
        if [[ "$next_line" =~ ^[[:space:]]{4}[^[:space:]] ]]; then
            insert_after=$((insert_after + 1))
        else
            break
        fi
    done

    # Insert the note at the right position
    local note_line="    $note_text"
    content=$(echo "$content" | awk -v n="$insert_after" -v line="$note_line" 'NR==n{print; print line; next} {print}')
    content=$(update_timestamp "$content")
    atomic_write "$TODOS_FILE" "$content"

    log_mutation "NOTE" "$id" "$desc" "note=\"$note_text\""

    echo "Added note to #$id: $note_text"
}

# ---- DISPATCH ----

usage() {
    cat << 'EOF'
Usage: axon todo <command> [args]

Commands:
  add "task" [--priority high|medium|low] [--notes "detail"]
                                            Add a new todo item
  done <id>                                 Mark item as completed
  defer <id> [--reason "why"]               Defer item to backlog
  drop <id> [--reason "why"]                Drop item permanently
  list [active|backlog|done|all]            List items (default: active)
  reprioritise <id> <high|medium|low>       Change item priority
  note <id> "note text"                     Add a note to an item

Examples:
  axon todo add "Implement CLAUDE.md bridge" --priority high
  axon todo add "Fix bug" --notes "Happens on page reload"
  axon todo note 1 "Need to check edge cases"
  axon todo done 1
  axon todo list all
EOF
    exit 1
}

SUBCMD="${1:-}"
shift || true
SUBARGS=("$@")

case "$SUBCMD" in
    add)        cmd_add "${SUBARGS[@]+"${SUBARGS[@]}"}" ;;
    done)       cmd_done "${SUBARGS[0]:-}" ;;
    defer)      cmd_defer "${SUBARGS[@]+"${SUBARGS[@]}"}" ;;
    drop)       cmd_drop "${SUBARGS[@]+"${SUBARGS[@]}"}" ;;
    list|ls)    cmd_list "${SUBARGS[0]:-active}" ;;
    reprioritise|reprioritize|repri)
                cmd_reprioritise "${SUBARGS[0]:-}" "${SUBARGS[1]:-}" ;;
    note)       cmd_note "${SUBARGS[@]+"${SUBARGS[@]}"}" ;;
    *)          usage ;;
esac
